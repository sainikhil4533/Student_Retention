GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash
COPILOT_SEMANTIC_PLANNER_ENABLED=true
COPILOT_SEMANTIC_CACHE_ENABLED=true
COPILOT_SEMANTIC_CACHE_MAX_ENTRIES=500
COPILOT_LOCAL_SEMANTIC_FALLBACK_ENABLED=true
GEMINI_MAX_RETRIES=3
GEMINI_RETRY_BASE_DELAY_SECONDS=2.0
COPILOT_SEMANTIC_PLANNER_ENABLED=true

DATABASE_URL=postgresql://username:password@host:port/database_name

FACULTY_ALERT_EMAIL=alerts@example.edu

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=mailer@example.edu
SMTP_FROM_EMAIL=mailer@example.edu
SMTP_PASSWORD=your_smtp_password_here

RECOVERY_WINDOW_DAYS=7
ENABLE_RECOVERY_ESCALATION_MONITOR=true
RECOVERY_ESCALATION_CHECK_SECONDS=60
FOLLOWUP_REMINDER_DELAY_HOURS=48

AUTH_SECRET_KEY=replace_with_a_long_random_secret

SUPABASE_AUTH_ENABLED=true
SUPABASE_AUTH_TIMEOUT_SECONDS=10
SUPABASE_PUBLISHABLE_KEY=your_supabase_publishable_key_here
SUPABASE_URL=https://your-project.supabase.co

TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_SMS_FROM=+10000000000
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
DEFAULT_PHONE_COUNTRY_CODE=+91
TWILIO_TIMEOUT_SECONDS=20

GUARDIAN_SMS_USE_LLM=true
